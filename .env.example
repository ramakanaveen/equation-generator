# Anthropic (default provider)
ANTHROPIC_API_KEY=your_key_here

# Vertex AI (set EQ_GEN_PROVIDER=vertex to use)
# EQ_GEN_PROVIDER=vertex
# EQ_GEN_VERTEX_PROJECT_ID=your_gcp_project_id
# EQ_GEN_VERTEX_REGION=us-east5

# Backend port (default: 8000)
# EQ_GEN_PORT=8000

# CORS — comma-separated origins (default: * — allow all)
# EQ_GEN_CORS_ORIGINS=http://myhost:5173,http://myhost:3000
