# Port for the Vite dev server (default: 5173)
VITE_PORT=5173

# Backend URL for the dev proxy (default: http://localhost:8000)
VITE_BACKEND_URL=http://localhost:8000

# Set this only when the UI is served from a different host than the backend.
# Leave empty (or unset) when using the Vite dev proxy — paths stay relative.
# VITE_API_BASE_URL=http://your-backend-host:8000
